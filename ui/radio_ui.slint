// Radio main UI - ESP32-C6 + ST7789 240x320 LCD
// Material Design components

import { MaterialWindow } from "../material-1.0/material.slint";
import { MaterialText } from "../material-1.0/material.slint";
import { MaterialPalette } from "../material-1.0/material.slint";
import { MaterialTypography } from "../material-1.0/material.slint";
import { FilledCard, OutlinedCard } from "../material-1.0/material.slint";
import { HorizontalDivider } from "../material-1.0/material.slint";
import { SmallAppBar } from "../material-1.0/material.slint";
import { LinearProgressIndicator } from "../material-1.0/material.slint";

export component RadioWindow inherits MaterialWindow {
    width: 240px;
    height: 320px;

    // Frequency in MHz x 10 (e.g. 1015 = 101.5 MHz)
    in-out property <int> freq-mhz-x10: 875;
    // Signal strength 0-75
    in-out property <int> rssi: 0;
    // Volume 0-15
    in-out property <int> volume: 8;
    // Boot-time RSSI sweep snapshot. Each value is in 0..=75 and
    // corresponds to one bucket of the FM band, evenly spaced from
    // bottom to top. Empty until [`publish_spectrum`] runs.
    in-out property <[int]> spectrum: [];
    // Index into `spectrum` of the bucket currently being played, or
    // -1 to disable the cursor highlight. Computed by the Rust UI loop
    // from `freq-mhz-x10`.
    in-out property <int> spectrum-cursor: -1;
    // RDS station name (8 chars)
    in-out property <string> station-name: "--------";
    // RDS RadioText (RT) free-form message; empty until decoded
    in-out property <string> radio-text: "";
    // Wall-clock text decoded from RDS Clock-Time (e.g. "19:42");
    // empty until the first valid CT frame is received.
    in-out property <string> clock-text: "";
    // RDS Programme Type label (e.g. "News", "Pop M"). Empty when no
    // RDS group has been decoded yet or when PTY = 0 ("None").
    in-out property <string> pty-label: "";
    // Stereo indicator text shown next to the RSSI value: "ST" when the
    // chip locks onto a stereo pilot, "MO" plain mono, "MO*" when the
    // firmware *automatically* forced mono in response to weak RSSI.
    in-out property <string> stereo-text: "MO";
    // True when the chip is in real stereo (used to colour the badge).
    in-out property <bool> stereo-active: false;
    // RDS-AF (alternative-frequency) badge. Empty when the broadcaster
    // has not announced an AF list; otherwise something like `AF·5`
    // (5 alternatives known) or `AF→` while a probe is active.
    in-out property <string> af-text: "";
    // True while the radio task is actively probing AF candidates.
    // Drives the `af-text` colour so the badge briefly highlights when
    // the receiver hops to a stronger frequency.
    in-out property <bool> af-active: false;
    // Whether muted
    in-out property <bool> muted: false;
    // WiFi connection status
    in-out property <bool> wifi-connected: false;
    // WiFi SSID for display
    in-out property <string> wifi-ssid: "";
    // IPv4 address as `"192.168.1.123"`, empty when WiFi has not yet
    // received DHCP. When non-empty, the footer prefers showing the
    // IP over the SSID so the user can read off the web-console URL.
    in-out property <string> web-ip: "";
    // Status line text
    in-out property <string> status-text: "Tuning...";
    // Preset indicator: e.g. "P 3/5" when slot 3 of 5 saved is active,
    // "P -/5" when current freq is unsaved, empty when none saved.
    in-out property <string> preset-text: "";

    // ----- OTA progress overlay -----
    // True while the OTA state machine is in any non-idle phase.
    // Shows a fullscreen modal that masks the radio UI so the user
    // can't accidentally tune mid-flash.
    in-out property <bool> ota-active: false;
    // Human-readable status line shown under the title, e.g.
    // "Downloading 256.0 / 1480.5 KiB (17%)" or "Activating…".
    in-out property <string> ota-status-text: "";
    // 0.0..1.0 normalised progress driving the LinearProgressIndicator.
    // The Rust side maps Connecting=0.05, Activating=0.95, Success=1.0,
    // Failed=1.0; Downloading uses received/total when known.
    in-out property <float> ota-progress: 0;
    // True when total length is unknown (server returned no
    // Content-Length): drives an indeterminate spinner instead of a
    // determinate bar.
    in-out property <bool> ota-indeterminate: false;
    // Mutually-exclusive flags driving the progress-bar / status-text
    // colour: success (tertiary green), failed (error red), otherwise
    // primary blue.
    in-out property <bool> ota-success: false;
    in-out property <bool> ota-failed: false;

    // Computed: integer/decimal split for frequency display
    property <int> freq-int: freq-mhz-x10 / 10;
    property <int> freq-dec: mod(freq-mhz-x10, 10);

    VerticalLayout {
        spacing: 0;

        // Top bar: SmallAppBar with an overlaid wall-clock readout pinned
        // to the right edge. We wrap the bar in a Rectangle so the clock
        // can sit on top of it (z-index style) without disturbing the
        // bar's internal layout.
        Rectangle {
            height: app-bar.preferred-height;

            app-bar := SmallAppBar {
                title: "ESP Radio";
                show-background: true;
            }

            // Wall-clock badge. Hidden when no CT has been decoded yet
            // so the bar reverts to its plain look.
            MaterialText {
                text: root.clock-text;
                style: MaterialTypography.title-small;
                color: MaterialPalette.on-surface;
                visible: root.clock-text != "";
                x: parent.width - self.preferred-width - 12px;
                y: (parent.height - self.preferred-height) / 2;
            }
        }

        VerticalLayout {
            padding: 8px;
            spacing: 6px;
            alignment: start;

            // Frequency display card (the focal element)
            FilledCard {
                height: 96px;

                VerticalLayout {
                    alignment: center;
                    padding: 6px;
                    spacing: 2px;

                    MaterialText {
                        text: "FM";
                        style: MaterialTypography.label-medium;
                        color: MaterialPalette.on-surface-variant;
                        horizontal-alignment: center;
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 2px;

                        MaterialText {
                            text: root.freq-int;
                            style: MaterialTypography.display-large;
                            color: MaterialPalette.primary;
                        }

                        MaterialText {
                            text: ".";
                            style: MaterialTypography.display-large;
                            color: MaterialPalette.primary;
                        }

                        MaterialText {
                            text: root.freq-dec;
                            style: MaterialTypography.display-large;
                            color: MaterialPalette.primary;
                        }

                        MaterialText {
                            text: " MHz";
                            style: MaterialTypography.title-small;
                            color: MaterialPalette.on-surface-variant;
                            vertical-alignment: bottom;
                        }
                    }
                }
            }

            // RDS Station name + RadioText
            OutlinedCard {
                height: 64px;

                VerticalLayout {
                    alignment: center;
                    padding: 4px;
                    spacing: 1px;

                    MaterialText {
                        text: root.station-name;
                        style: MaterialTypography.title-medium;
                        color: MaterialPalette.on-surface;
                        horizontal-alignment: center;
                    }

                    // RadioText (RT) marquee — scrolls horizontally if it
                    // doesn't fit the container; otherwise sits centered.
                    rt-clip := Rectangle {
                        clip: true;
                        height: 14px;

                        property <length> text-w: rt-label.preferred-width;
                        // Total scrollable distance: text width + container width
                        // (so the text fully exits before re-entering).
                        property <length> cycle: rt-clip.text-w + self.width;
                        // 30 px / second scroll speed. animation-tick() returns ms.
                        property <length> offset: (animation-tick() / 1ms) * 0.03px;

                        rt-label := MaterialText {
                            text: root.radio-text == "" ? "—" : root.radio-text;
                            style: MaterialTypography.label-small;
                            color: MaterialPalette.on-surface-variant;
                            // When RT fits the container: center it (no scroll).
                            // Otherwise: scroll right → left, looping every `cycle`.
                            x: rt-clip.text-w <= rt-clip.width
                                ? (rt-clip.width - rt-clip.text-w) / 2
                                : rt-clip.width - mod(rt-clip.offset, rt-clip.cycle);
                            y: (parent.height - self.preferred-height) / 2;
                            // Force single-line so preferred-width stays meaningful.
                            wrap: no-wrap;
                        }
                    }
                }

                // Programme Type badge pinned to the top-right corner.
                // Hidden when no PTY has been decoded so the card stays
                // visually clean. Slightly rounded background so it reads
                // as a Material "chip" without pulling in another import.
                pty-chip := Rectangle {
                    visible: root.pty-label != "";
                    background: MaterialPalette.secondary-container;
                    border-radius: 6px;
                    width: pty-text.preferred-width + 8px;
                    height: pty-text.preferred-height + 2px;
                    x: parent.width - self.width - 6px;
                    y: 4px;

                    pty-text := MaterialText {
                        text: root.pty-label;
                        style: MaterialTypography.label-small;
                        color: MaterialPalette.on-secondary-container;
                        x: 4px;
                        y: 1px;
                    }
                }
            }

            // Boot-time RSSI spectrum strip. One bar per bucket; the
            // bucket currently being played is highlighted in the
            // accent colour. Hidden when the sweep has not produced
            // any data yet (e.g. very early boot or sweep failure).
            Rectangle {
                height: 28px;
                background: MaterialPalette.surface-container-highest;
                border-radius: 4px;
                visible: root.spectrum.length > 0;

                HorizontalLayout {
                    padding: 2px;
                    spacing: 1px;
                    alignment: stretch;

                    for value[idx] in root.spectrum: Rectangle {
                        // Active vs idle colouring. The cursor turns the
                        // bar primary so the user can locate the current
                        // tuning point at a glance.
                        background: idx == root.spectrum-cursor
                            ? MaterialPalette.primary
                            : MaterialPalette.tertiary;
                        // Bar height tracks RSSI 0..=75 mapped onto the
                        // strip height. Floor at 1 px so empty buckets
                        // still show a baseline tick.
                        height: max(1px, parent.height * min(value / 75.0, 1.0));
                        // Anchor to the bottom edge so taller bars grow
                        // upwards like a histogram.
                        y: parent.height - self.height;
                        border-radius: 1px;
                        horizontal-stretch: 1;
                    }
                }
            }

            // Signal strength bar
            VerticalLayout {
                spacing: 2px;

                HorizontalLayout {
                    alignment: space-between;

                    MaterialText {
                        text: "Signal";
                        style: MaterialTypography.label-small;
                        color: MaterialPalette.on-surface-variant;
                    }

                    HorizontalLayout {
                        spacing: 4px;

                        // Stereo / Mono badge. Coloured `primary` for true
                        // stereo, `outline` (muted) for mono / auto-mono.
                        MaterialText {
                            text: root.stereo-text;
                            style: MaterialTypography.label-small;
                            color: root.stereo-active
                                ? MaterialPalette.primary
                                : MaterialPalette.outline;
                        }

                        // RDS-AF badge. Hidden when no AF list received;
                        // brightens to `primary` while the follower is
                        // actively probing so the user has a beat of
                        // visual feedback during the brief audio dip.
                        MaterialText {
                            text: root.af-text;
                            visible: root.af-text != "";
                            style: MaterialTypography.label-small;
                            color: root.af-active
                                ? MaterialPalette.primary
                                : MaterialPalette.outline;
                        }

                        MaterialText {
                            text: root.rssi;
                            style: MaterialTypography.label-small;
                            color: MaterialPalette.on-surface;
                        }
                    }
                }

                LinearProgressIndicator {
                    progress: min(root.rssi / 75, 1.0);
                }
            }

            // Volume bar
            VerticalLayout {
                spacing: 2px;

                HorizontalLayout {
                    alignment: space-between;

                    MaterialText {
                        text: root.muted ? "Muted" : "Volume";
                        style: MaterialTypography.label-small;
                        color: root.muted ? MaterialPalette.error : MaterialPalette.on-surface-variant;
                    }

                    MaterialText {
                        text: root.volume;
                        style: MaterialTypography.label-small;
                        color: MaterialPalette.on-surface;
                    }
                }

                LinearProgressIndicator {
                    progress: root.volume / 15;
                }
            }

            // Spacer
            Rectangle {
                vertical-stretch: 1;
            }

            HorizontalDivider { }

            // Footer: WiFi and status
            HorizontalLayout {
                alignment: space-between;
                spacing: 4px;

                MaterialText {
                    text: root.wifi-connected
                        ? (root.web-ip != "" ? "http://" + root.web-ip : "W: " + root.wifi-ssid)
                        : "W: offline";
                    style: MaterialTypography.label-small;
                    color: root.wifi-connected ? MaterialPalette.primary : MaterialPalette.outline;
                    overflow: elide;
                }

                MaterialText {
                    text: root.preset-text;
                    visible: root.preset-text != "";
                    style: MaterialTypography.label-small;
                    color: MaterialPalette.primary;
                }

                MaterialText {
                    text: root.status-text;
                    style: MaterialTypography.label-small;
                    color: MaterialPalette.outline;
                }
            }
        }
    }

    // ----- OTA progress overlay -----
    //
    // Sibling of the main VerticalLayout, parented directly under
    // MaterialWindow (which inherits plain `Window`, so children are
    // absolutely positioned). Sits above all other UI when visible.
    //
    // Hidden when ota-active is false; the Slint compiler still
    // evaluates child bindings, but `visible: false` skips both the
    // input handling and the rendering pass.
    Rectangle {
        visible: root.ota-active;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        // Translucent scrim so the radio UI shows through faintly,
        // matching Material's modal-overlay convention.
        background: #000000c0;

        // TouchArea swallows pointer events so the rotary input task's
        // long-press / button events still flow (those go through the
        // hardware GPIO path, not Slint), but stray screen taps don't
        // reach the underlying buttons during a flash.
        TouchArea { }

        FilledCard {
            x: 16px;
            y: (parent.height - self.height) / 2;
            width: parent.width - 32px;
            height: 168px;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                alignment: center;

                MaterialText {
                    text: "Firmware update";
                    style: MaterialTypography.title-medium;
                    color: MaterialPalette.on-surface;
                    horizontal-alignment: center;
                }

                MaterialText {
                    text: root.ota-status-text;
                    style: MaterialTypography.body-small;
                    color: root.ota-failed
                        ? MaterialPalette.error
                        : MaterialPalette.on-surface-variant;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                LinearProgressIndicator {
                    width: parent.width;
                    progress: root.ota-progress;
                    indeterminate: root.ota-indeterminate;
                }

                // Reboot hint: only shown on Success so the listener
                // knows the new image is staged but not yet running.
                MaterialText {
                    text: "Power-cycle to apply";
                    visible: root.ota-success;
                    style: MaterialTypography.label-small;
                    color: MaterialPalette.primary;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
