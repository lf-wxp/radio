// Slint UI definition file - Demo for ST7789 240x320 LCD display
// Using Material Design components from material-1.0 library

import { MaterialWindow } from "../material-1.0/material.slint";
import { MaterialText } from "../material-1.0/material.slint";
import { MaterialPalette } from "../material-1.0/material.slint";
import { MaterialTypography } from "../material-1.0/material.slint";
import { FilledCard, OutlinedCard } from "../material-1.0/material.slint";
import { HorizontalDivider } from "../material-1.0/material.slint";
import { SmallAppBar } from "../material-1.0/material.slint";
import { LinearProgressIndicator } from "../material-1.0/material.slint";

export component ExampleWindow inherits MaterialWindow {
    width: 240px;
    height: 320px;

    in-out property <int> counter: 0;
    in-out property <string> status-text: "ESP32-C6 Radio";

    VerticalLayout {
        spacing: 0;

        // Top App Bar
        SmallAppBar {
            title: "ESP Radio";
            show-background: true;
        }

        // Main content area
        VerticalLayout {
            padding: 12px;
            spacing: 12px;
            alignment: start;

            // Counter card
            FilledCard {
                height: 100px;

                VerticalLayout {
                    alignment: center;
                    padding: 12px;
                    spacing: 4px;

                    MaterialText {
                        text: "Counter";
                        style: MaterialTypography.label-medium;
                        color: MaterialPalette.on-surface-variant;
                        horizontal-alignment: center;
                    }

                    MaterialText {
                        text: root.counter;
                        style: MaterialTypography.display-small;
                        color: MaterialPalette.primary;
                        horizontal-alignment: center;
                    }
                }
            }

            // Status card
            OutlinedCard {
                height: 72px;

                VerticalLayout {
                    alignment: center;
                    padding: 12px;
                    spacing: 4px;

                    MaterialText {
                        text: "Status";
                        style: MaterialTypography.label-small;
                        color: MaterialPalette.on-surface-variant;
                        horizontal-alignment: center;
                    }

                    MaterialText {
                        text: root.status-text;
                        style: MaterialTypography.title-medium;
                        color: MaterialPalette.on-surface;
                        horizontal-alignment: center;
                    }
                }
            }

            // Progress indicator
            VerticalLayout {
                spacing: 4px;

                MaterialText {
                    text: "Progress";
                    style: MaterialTypography.label-small;
                    color: MaterialPalette.on-surface-variant;
                }

                LinearProgressIndicator {
                    progress: mod(root.counter, 100) / 100;
                }
            }

            // Spacer
            Rectangle {
                vertical-stretch: 1;
            }

            // Footer divider and text
            HorizontalDivider { }

            MaterialText {
                text: "Slint + ST7789 Material";
                style: MaterialTypography.label-small;
                color: MaterialPalette.outline;
                horizontal-alignment: center;
            }
        }
    }
}
